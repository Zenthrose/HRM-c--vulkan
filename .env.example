# HRM Environment Variables

# Configuration directory (overrides default ./config or ~/.hrm/config)
# HRM_CONFIG_DIR=/path/to/config

# Log directory (overrides default ./logs)
# HRM_LOG_DIR=/path/to/logs

# Model directory (overrides default ~/.hrm/models)
# HRM_MODEL_DIR=/path/to/models

# Cloud storage API key
# HRM_CLOUD_API_KEY=your_api_key_here

# Log level (debug, info, warn, error)
# HRM_LOG_LEVEL=info