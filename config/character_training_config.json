{
  "model": {
    "char_vocab_size": 100000,
    "hidden_size": 768,
    "num_layers": 12,
    "num_heads": 12,
    "max_seq_length": 2048
  },
  "training": {
    "learning_rate": 0.00005,
    "batch_size": 4,
    "gradient_accumulation_steps": 8,
    "max_epochs": 10,
    "context_length": 1024,
    "save_every_epochs": 2
  },
  "data": {
    "dataset_path": "./data/text",
    "train_val_split": 0.9,
    "shuffle_sequences": true
  },
  "generation": {
    "temperature": 1.0,
    "top_p": 0.9,
    "max_length": 500
  }
}
